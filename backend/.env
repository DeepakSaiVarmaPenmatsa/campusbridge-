# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/campusbridge

# JWT
JWT_SECRET=campusbridge_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# Email (configure with your SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=CampusBridge <noreply@campusbridge.edu>

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads

# Auto-escalation (hours)
ESCALATION_LOW=72
ESCALATION_MEDIUM=48
ESCALATION_HIGH=24
ESCALATION_CRITICAL=6
